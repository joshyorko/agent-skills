#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: rcc-dagger-mcp [dagger mcp options]

Expose a local Dagger module as a stdio MCP server.

By default, the current working directory is used when it contains dagger.json
and .dagger/. If the current directory is not a Dagger module, the server starts
without a module. Set RCC_DAGGER_REPO or RCC_DAGGER_MODULE only when you want to
pin the server to a specific checkout regardless of current directory.

Examples:
  rcc-dagger-mcp
  RCC_DAGGER_REPO=/path/to/rcc rcc-dagger-mcp
  codex mcp add rcc-dagger -- /path/to/rcc-dagger-mcp

Use the pinned env form only for a fixed module:
  codex mcp add rcc-dagger --env RCC_DAGGER_REPO=/path/to/rcc -- /path/to/rcc-dagger-mcp
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v dagger >/dev/null 2>&1; then
  echo "dagger CLI is required to expose the RCC Dagger module as MCP." >&2
  exit 127
fi

run_dagger_mcp() {
  python3 "$script_dir/rcc-dagger-mcp-filter.py" "$@"
}

rcc_repo="${RCC_DAGGER_REPO:-${RCC_DAGGER_MODULE:-}}"
if [[ -z "$rcc_repo" && -f dagger.json && -d .dagger ]]; then
  rcc_repo="$PWD"
fi

if [[ -z "$rcc_repo" ]]; then
  run_dagger_mcp --no-mod --env-privileged "$@"
  exit $?
fi

rcc_repo="$(python3 - "$rcc_repo" <<'PY'
import sys
from pathlib import Path

print(Path(sys.argv[1]).expanduser().resolve())
PY
)"

if [[ ! -f "$rcc_repo/dagger.json" || ! -d "$rcc_repo/.dagger" ]]; then
  echo "Dagger module path must contain dagger.json and .dagger/: $rcc_repo" >&2
  exit 2
fi

run_dagger_mcp --mod "$rcc_repo" "$@"
